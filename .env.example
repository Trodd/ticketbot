# Discord Bot Token (required)
DISCORD_TOKEN=your_bot_token_here

# Guild ID for registering commands (optional, leave empty for global commands)
GUILD_ID=your_guild_id_here

# Category ID where ticket channels will be created (optional)
TICKET_CATEGORY_ID=your_category_id_here

# Support Role ID - users with this role can see all tickets (optional)
SUPPORT_ROLE_ID=your_support_role_id_here

# Log Channel ID - where ticket actions will be logged (optional)
LOG_CHANNEL_ID=your_log_channel_id_here
