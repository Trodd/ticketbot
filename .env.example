# ═══════════════════════════════════════════════════════════════════════════════
#                           TICKETBOT CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
# Just fill in the blanks! Delete any categories/fields you don't need.
# Leave all CATEGORY_ lines empty/deleted to use defaults.


# ═══════════════════════════════════════════════════════════════════════════════
#                              REQUIRED SETTINGS
# ═══════════════════════════════════════════════════════════════════════════════

# Your Discord Bot Token (from https://discord.com/developers/applications)
DISCORD_TOKEN=

# Your Discord Server ID (right-click server name → Copy Server ID)
GUILD_ID=

# Category channel where tickets go (right-click category → Copy Channel ID)
TICKET_CATEGORY_ID=

# Support role that sees ALL tickets (right-click role → Copy Role ID)
SUPPORT_ROLE_ID=

# Channel where transcripts are posted (right-click channel → Copy Channel ID)
LOG_CHANNEL_ID=


# ═══════════════════════════════════════════════════════════════════════════════
#                           TICKET CATEGORY 1
# ═══════════════════════════════════════════════════════════════════════════════

# Basic Info
CATEGORY_1_ID=support
CATEGORY_1_NAME=Support Ticket
CATEGORY_1_DESCRIPTION=Get help from our support team
CATEGORY_1_EMOJI=🎫
CATEGORY_1_COLOR=5793266
CATEGORY_1_HAS_APPROVAL=false
CATEGORY_1_ROLES=

# Field 1
CATEGORY_1_FIELD_1_ID=subject
CATEGORY_1_FIELD_1_LABEL=Subject
CATEGORY_1_FIELD_1_PLACEHOLDER=What do you need help with?
CATEGORY_1_FIELD_1_REQUIRED=true
CATEGORY_1_FIELD_1_MULTILINE=false
CATEGORY_1_FIELD_1_MAX_LENGTH=100

# Field 2
CATEGORY_1_FIELD_2_ID=description
CATEGORY_1_FIELD_2_LABEL=Description
CATEGORY_1_FIELD_2_PLACEHOLDER=Describe your issue in detail...
CATEGORY_1_FIELD_2_REQUIRED=true
CATEGORY_1_FIELD_2_MULTILINE=true
CATEGORY_1_FIELD_2_MAX_LENGTH=1000


# ═══════════════════════════════════════════════════════════════════════════════
#                           TICKET CATEGORY 2
# ═══════════════════════════════════════════════════════════════════════════════

# Basic Info
CATEGORY_2_ID=appeal
CATEGORY_2_NAME=Ban Appeal
CATEGORY_2_DESCRIPTION=Appeal a ban or punishment
CATEGORY_2_EMOJI=⚖️
CATEGORY_2_COLOR=16761095
CATEGORY_2_HAS_APPROVAL=true
CATEGORY_2_ROLES=

# Field 1
CATEGORY_2_FIELD_1_ID=punishment
CATEGORY_2_FIELD_1_LABEL=What punishment are you appealing?
CATEGORY_2_FIELD_1_PLACEHOLDER=Ban, Mute, Warn, etc.
CATEGORY_2_FIELD_1_REQUIRED=true
CATEGORY_2_FIELD_1_MULTILINE=false
CATEGORY_2_FIELD_1_MAX_LENGTH=100

# Field 2
CATEGORY_2_FIELD_2_ID=reason
CATEGORY_2_FIELD_2_LABEL=Why should we accept your appeal?
CATEGORY_2_FIELD_2_PLACEHOLDER=Explain why you deserve another chance...
CATEGORY_2_FIELD_2_REQUIRED=true
CATEGORY_2_FIELD_2_MULTILINE=true
CATEGORY_2_FIELD_2_MAX_LENGTH=1000


