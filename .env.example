# ═══════════════════════════════════════════════════════════════════════════════
#                           TICKET CATEGORY 4
# ═══════════════════════════════════════════════════════════════════════════════

# Basic Info
CATEGORY_4_ID=report
CATEGORY_4_NAME=Report
CATEGORY_4_DESCRIPTION=Report a user or issue
CATEGORY_4_EMOJI=🚨
CATEGORY_4_COLOR=15548997
CATEGORY_4_HAS_APPROVAL=false
CATEGORY_4_ROLES=

# Field 1
CATEGORY_4_FIELD_1_ID=target
CATEGORY_4_FIELD_1_LABEL=Who/What are you reporting?
CATEGORY_4_FIELD_1_PLACEHOLDER=Username or description
CATEGORY_4_FIELD_1_REQUIRED=true
CATEGORY_4_FIELD_1_MULTILINE=false
CATEGORY_4_FIELD_1_MAX_LENGTH=200

# Field 2
CATEGORY_4_FIELD_2_ID=details
CATEGORY_4_FIELD_2_LABEL=Details
CATEGORY_4_FIELD_2_PLACEHOLDER=What happened? Be specific...
CATEGORY_4_FIELD_2_REQUIRED=true
CATEGORY_4_FIELD_2_MULTILINE=true
CATEGORY_4_FIELD_2_MAX_LENGTH=1000

# Field 3 (optional field example)
CATEGORY_4_FIELD_3_ID=evidence
CATEGORY_4_FIELD_3_LABEL=Evidence (optional)
CATEGORY_4_FIELD_3_PLACEHOLDER=Links to screenshots, videos, etc.
CATEGORY_4_FIELD_3_REQUIRED=false
CATEGORY_4_FIELD_3_MULTILINE=true
CATEGORY_4_FIELD_3_MAX_LENGTH=500


# ═══════════════════════════════════════════════════════════════════════════════
#                     ADD MORE CATEGORIES (5-10) BELOW
# ═══════════════════════════════════════════════════════════════════════════════
# Copy and paste a category block above, change the number (5, 6, 7, etc.)
# You can have up to 10 categories total, each with up to 5 fields.


# ═══════════════════════════════════════════════════════════════════════════════
#                              QUICK REFERENCE
# ═══════════════════════════════════════════════════════════════════════════════
#
# ID          = unique lowercase name (no spaces) - used for channel names
# NAME        = what users see in buttons/commands
# DESCRIPTION = short description
# EMOJI       = any emoji
# COLOR       = decimal color (see below)
# HAS_APPROVAL= true (Approve/Deny buttons) or false (just Close)
# ROLES       = extra role IDs that can see this category (comma-separated)
#
# FIELD OPTIONS:
# ID          = unique lowercase name for this field
# LABEL       = the question shown to user
# PLACEHOLDER = hint text (grayed out)
# REQUIRED    = true or false
# MULTILINE   = true (big text box) or false (single line)
# MAX_LENGTH  = max characters allowed
#
# COLORS:
# Blue     = 5793266      Green  = 5763719      Yellow = 16761095
# Orange   = 15105570     Red    = 15548997     Purple = 10181046
# Pink     = 15277667     Gold   = 15844367     Gray   = 9807270
#
# HOW TO GET IDs:
# 1. Enable Developer Mode: User Settings → Advanced → Developer Mode
# 2. Right-click anything → Copy ID
#
# ═══════════════════════════════════════════════════════════════════════════════
